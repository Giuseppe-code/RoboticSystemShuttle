# Godot-specific ignores
.godot/
*.translation
*.pot
*.mo

# Generated import files
*.import
!ackermann/assets/arm4/*.glb.import

# Exported builds
/export/
/dist/

# Generated simulation outputs
/artifacts/*
!/artifacts/.gitkeep
/logs/*
!/logs/.gitkeep

# Python cache
__pycache__/
*.py[cod]

# User-specific settings
.vscode/
.idea/
.venv/

# OS-specific
.DS_Store
Thumbs.db
